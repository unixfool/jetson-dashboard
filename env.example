# ─── Jetson Dashboard - Environment Configuration

# ─── Security ────
# Enable authentication (recommended: true)
AUTH_ENABLED=false
# Username for login
AUTH_USERNAME=admin
# Password for login — CHANGE THIS before sharing
AUTH_PASSWORD=changeme
# Secret key used to sign JWT tokens — CHANGE THIS
AUTH_SECRET=jetson-dashboard-change-this-secret-key
# Token duration in seconds (86400 = 24 hours)
AUTH_TOKEN_TTL=86400

# ─── Dashboard ────
# SSL port: 8443
DASHBOARD_PORT=8080 

# ─── Hardware Override (leave empty for auto-detection) ────
JETSON_MODEL=
JETPACK_VERSION=
CUDA_VERSION=
CUDNN_VERSION=
TENSORRT_VERSION=

# ─── Backend ────
# Metrics refresh interval in seconds
METRICS_INTERVAL=1.5

# ─── Docker ────
DOCKER_SOCKET=/var/run/docker.sock